# Простий куб
# 8 вершин, 6 граней (12 трикутників)

# Вершини
v -1.0  1.0  1.0
v -1.0 -1.0  1.0
v  1.0 -1.0  1.0
v  1.0  1.0  1.0
v -1.0  1.0 -1.0
v -1.0 -1.0 -1.0
v  1.0 -1.0 -1.0
v  1.0  1.0 -1.0

# Нормалі (по одній на кожну сторону куба)
vn  0.0  0.0  1.0
vn  0.0  0.0 -1.0
vn  0.0  1.0  0.0
vn  0.0 -1.0  0.0
vn  1.0  0.0  0.0
vn -1.0  0.0  0.0

# Грані (полігони)
# Передня сторона (нормаль 1)
f 1//1 2//1 3//1
f 1//1 3//1 4//1

# Задня сторона (нормаль 2)
f 5//2 7//2 6//2
f 5//2 8//2 7//2

# Верхня сторона (нормаль 3)
f 1//3 4//3 8//3
f 1//3 8//3 5//3

# Нижня сторона (нормаль 4)
f 2//4 6//4 7//4
f 2//4 7//4 3//4

# Права сторона (нормаль 5)
f 3//5 7//5 8//5
f 3//5 8//5 4//5

# Ліва сторона (нормаль 6)
f 1//6 5//6 6//6
f 1//6 6//6 2//6
